# LƯU Ý: Key AI mặc định (Gemini + Groq) KHÔNG còn nhúng vào frontend nữa.
# Chúng được giấu trong Firebase Cloud Functions:
#   - Production: firebase functions:secrets:set GEMINI_API_KEY (và GROQ_API_KEY)
#   - Emulator cục bộ: đặt trong functions/.secret.local (đã .gitignore)
# Các biến dưới đây chỉ còn dùng cho mục đích tham khảo / công cụ ngoài frontend.

# GEMINI_API_KEY: (backend) key Gemini mặc định cho Cloud Function aiProxy.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GROQ_API_KEY: (backend) key Llama-3-8B (Groq) mặc định cho Cloud Function aiProxy.
# Lấy key miễn phí tại https://console.groq.com
GROQ_API_KEY="MY_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
