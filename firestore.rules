rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null; // Standard auth
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidRule(data) {
      return data.keys().hasAll(['userId', 'title', 'content', 'type', 'updatedAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && ( !('description' in data.keys()) || (data.description is string && data.description.size() <= 2000) )
        && data.content is string && data.content.size() <= 50000
        && data.type is string && data.type.size() <= 40
        && ( !('tags' in data.keys()) || (data.tags is list && data.tags.size() <= 50) )
        && ( !('authorName' in data.keys()) || (data.authorName is string && data.authorName.size() <= 100) )
        && data.updatedAt is timestamp;
    }

    function isValidSkill(data) {
      return data.keys().hasAll(['userId', 'title', 'updatedAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && ( !('description' in data.keys()) || (data.description is string && data.description.size() <= 2000) )
        && ( !('instructions' in data.keys()) || (data.instructions is string && data.instructions.size() <= 50000) )
        && ( !('inputs' in data.keys()) || (data.inputs is list && data.inputs.size() <= 50) )
        && ( !('steps' in data.keys()) || (data.steps is list && data.steps.size() <= 50) )
        && ( !('authorName' in data.keys()) || (data.authorName is string && data.authorName.size() <= 100) )
        && data.updatedAt is timestamp;
    }

    function isValidTemplate(data) {
      return data.keys().hasAll(['userId', 'title', 'blocks', 'createdAt', 'updatedAt']) 
        && data.userId is string && data.userId.size() <= 128
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && ( !('description' in data.keys()) || (data.description is string && data.description.size() <= 2000) )
        && ( !('category' in data.keys()) || (data.category is string && data.category.size() <= 100) )
        && ( !('variables' in data.keys()) || (data.variables is list && data.variables.size() <= 50) )
        && ( !('version' in data.keys()) || (data.version is string && data.version.size() <= 50) )
        && ( !('parentPromptId' in data.keys()) || (data.parentPromptId is string && data.parentPromptId.size() <= 128) )
        && ( !('changelog' in data.keys()) || (data.changelog is string && data.changelog.size() <= 2000) )
        && ( !('tags' in data.keys()) || (data.tags is list && data.tags.size() <= 50) )
        && ( !('language' in data.keys()) || (data.language is string && data.language.size() <= 20) )
        && ( !('difficultyLevel' in data.keys()) || (data.difficultyLevel is string && data.difficultyLevel.size() <= 20) )
        && ( !('useCase' in data.keys()) || (data.useCase is string && data.useCase.size() <= 100) )
        && ( !('aiConfig' in data.keys()) || (data.aiConfig is map) )
        && ( !('metrics' in data.keys()) || (data.metrics is map) )
        && ( !('fewShots' in data.keys()) || (data.fewShots is list && data.fewShots.size() <= 20) )
        && ( !('isPublic' in data.keys()) || (data.isPublic is bool) )
        && ( !('status' in data.keys()) || (data.status is string && data.status.size() <= 20) )
        && ( !('authorId' in data.keys()) || (data.authorId is string && data.authorId.size() <= 128) )
        && ( !('authorName' in data.keys()) || (data.authorName is string && data.authorName.size() <= 100) )
        && ( !('workspaceId' in data.keys()) || (data.workspaceId is string && data.workspaceId.size() <= 128) )
        && ( !('versions' in data.keys()) || (data.versions is list && data.versions.size() <= 20) )
        && data.blocks is list && data.blocks.size() <= 50
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    // H1: một lượt "bump" metrics hợp lệ — chỉ các counter xã hội, mỗi counter đổi
    // tối đa ±1/lần, usageCount không được giảm, averageRating không đổi qua đường này.
    function counterDelta(newM, oldM, key) {
      return newM.get(key, 0) - oldM.get(key, 0);
    }

    function isMetricsBump(newM, oldM) {
      return newM is map
        && newM.keys().hasOnly(['usageCount', 'upvotes', 'likes', 'saves', 'averageRating'])
        && counterDelta(newM, oldM, 'usageCount') >= 0 && counterDelta(newM, oldM, 'usageCount') <= 1
        && counterDelta(newM, oldM, 'upvotes') >= -1 && counterDelta(newM, oldM, 'upvotes') <= 1
        && counterDelta(newM, oldM, 'likes') >= -1 && counterDelta(newM, oldM, 'likes') <= 1
        && counterDelta(newM, oldM, 'saves') >= -1 && counterDelta(newM, oldM, 'saves') <= 1
        && counterDelta(newM, oldM, 'averageRating') == 0;
    }

    function isValidWorkspace(data) {
      return data.keys().hasAll(['userId', 'name', 'createdAt', 'updatedAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && ( !('color' in data.keys()) || (data.color is string && data.color.size() <= 20) )
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidPersona(data) {
      return data.keys().hasAll(['userId', 'name', 'systemInstructions', 'createdAt', 'updatedAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.systemInstructions is string && data.systemInstructions.size() <= 20000
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidBookmark(data) {
      return data.keys().hasAll(['userId', 'templateId', 'createdAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.templateId is string && data.templateId.size() > 0 && data.templateId.size() <= 128
        && data.createdAt is timestamp;
    }

    function isValidSharedApp(data) {
      return data.keys().hasAll(['userId', 'name', 'nodes', 'createdAt', 'updatedAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && ( !('description' in data.keys()) || (data.description is string && data.description.size() <= 2000) )
        && data.nodes is list && data.nodes.size() <= 100
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidHealthSuite(data) {
      return data.keys().hasAll(['userId', 'name', 'createdAt', 'updatedAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && ( !('prompt' in data.keys()) || (data.prompt is string && data.prompt.size() <= 50000) )
        && ( !('model' in data.keys()) || (data.model is string && data.model.size() <= 60) )
        && ( !('workspaceId' in data.keys()) || (data.workspaceId is string && data.workspaceId.size() <= 128) )
        && ( !('testCases' in data.keys()) || (data.testCases is list && data.testCases.size() <= 50) )
        && ( !('runs' in data.keys()) || (data.runs is list && data.runs.size() <= 50) )
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    match /templates/{templateId} {
      // resource == null: doc chưa tồn tại — cho user đã đăng nhập get (trả exists=false)
      // để client kiểm tra trước khi tạo mới; nếu không, resource.data sẽ lỗi → permission-denied.
      allow get: if isValidId(templateId) && (
        (resource == null && isSignedIn())
        || isOwner(resource.data.userId)
        || resource.data.get('isPublic', false) == true
      );
      
      allow list: if resource.data.get('isPublic', false) == true || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow create: if isValidId(templateId)
        && isSignedIn()
        && isValidTemplate(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time
        && incoming().userId == request.auth.uid;
        
      allow update: if isValidId(templateId)
        && isSignedIn()
        && isOwner(existing().userId)
        && isValidTemplate(incoming())
        // Immutable owner & creation time
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        // Action: Edit Template
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'category', 'blocks', 'variables', 'version', 'parentPromptId', 'changelog', 'tags', 'language', 'difficultyLevel', 'useCase', 'aiConfig', 'metrics', 'fewShots', 'isPublic', 'status', 'authorId', 'authorName', 'workspaceId', 'versions', 'updatedAt']);

      // H1: bất kỳ user đã đăng nhập nào cũng được "bump" metrics của template PUBLIC
      // (mở vào Builder +1 usageCount, thích/bỏ thích ±1 likes). Chỉ field metrics
      // được đổi và delta bị chặn trong isMetricsBump.
      allow update: if isValidId(templateId)
        && isSignedIn()
        && existing().get('isPublic', false) == true
        && incoming().diff(existing()).affectedKeys().hasOnly(['metrics'])
        && isMetricsBump(incoming().metrics, existing().get('metrics', {}));

      allow delete: if isValidId(templateId) && isOwner(existing().userId);
    }

    match /suggestionModels/{uid} {
      allow get:    if isOwner(uid);
      allow create: if isOwner(uid)
                    && incoming().userId == uid
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
      allow update: if isOwner(uid)
                    && incoming().userId == uid
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time;
      allow delete: if isOwner(uid);
    }

    match /projects/{projectId} {
      allow get: if isValidId(projectId) && isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isValidId(projectId)
        && isSignedIn()
        && incoming().userId == request.auth.uid
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
      allow update: if isValidId(projectId)
        && isSignedIn()
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
      allow delete: if isValidId(projectId) && isSignedIn() && existing().userId == request.auth.uid;
    }

    match /rules/{ruleId} {
      allow get: if isValidId(ruleId) && isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isValidId(ruleId)
        && isSignedIn()
        && isValidRule(incoming())
        && incoming().userId == request.auth.uid
        && incoming().updatedAt == request.time;
      allow update: if isValidId(ruleId)
        && isSignedIn()
        && isOwner(existing().userId)
        && isValidRule(incoming())
        && incoming().userId == existing().userId
        && incoming().updatedAt == request.time;
      allow delete: if isValidId(ruleId) && isOwner(existing().userId);
    }

    match /skills/{skillId} {
      allow get: if isValidId(skillId) && isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isValidId(skillId)
        && isSignedIn()
        && isValidSkill(incoming())
        && incoming().userId == request.auth.uid
        && incoming().updatedAt == request.time;
      allow update: if isValidId(skillId)
        && isSignedIn()
        && isOwner(existing().userId)
        && isValidSkill(incoming())
        && incoming().userId == existing().userId
        && incoming().updatedAt == request.time;
      allow delete: if isValidId(skillId) && isOwner(existing().userId);
    }

    match /workspaces/{workspaceId} {
      allow get: if isValidId(workspaceId) && isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isValidId(workspaceId)
        && isSignedIn()
        && isValidWorkspace(incoming())
        && incoming().userId == request.auth.uid
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
      allow update: if isValidId(workspaceId)
        && isSignedIn()
        && isOwner(existing().userId)
        && isValidWorkspace(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
      allow delete: if isValidId(workspaceId) && isOwner(existing().userId);
    }

    match /personas/{personaId} {
      allow get: if isValidId(personaId) && isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isValidId(personaId)
        && isSignedIn()
        && isValidPersona(incoming())
        && incoming().userId == request.auth.uid
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
      allow update: if isValidId(personaId)
        && isSignedIn()
        && isOwner(existing().userId)
        && isValidPersona(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
      allow delete: if isValidId(personaId) && isOwner(existing().userId);
    }

    match /bookmarks/{bookmarkId} {
      allow get: if isValidId(bookmarkId) && isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isValidId(bookmarkId)
        && isSignedIn()
        && isValidBookmark(incoming())
        && incoming().userId == request.auth.uid
        && incoming().createdAt == request.time;
      allow delete: if isValidId(bookmarkId) && isOwner(existing().userId);
    }

    // App chia sẻ: bất kỳ ai có link đều ĐỌC được (để chạy client bằng auth của họ);
    // chỉ chủ sở hữu mới xuất bản/sửa/xoá.
    match /sharedApps/{appId} {
      allow get: if isValidId(appId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isValidId(appId)
        && isSignedIn()
        && isValidSharedApp(incoming())
        && incoming().userId == request.auth.uid
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
      allow update: if isValidId(appId)
        && isSignedIn()
        && isOwner(existing().userId)
        && isValidSharedApp(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
      allow delete: if isValidId(appId) && isOwner(existing().userId);
    }

    match /healthSuites/{suiteId} {
      allow get: if isValidId(suiteId) && isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isValidId(suiteId)
        && isSignedIn()
        && isValidHealthSuite(incoming())
        && incoming().userId == request.auth.uid
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
      allow update: if isValidId(suiteId)
        && isSignedIn()
        && isOwner(existing().userId)
        && isValidHealthSuite(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
      allow delete: if isValidId(suiteId) && isOwner(existing().userId);
    }
  }
}
